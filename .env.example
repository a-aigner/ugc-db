# Copy this file to .env and adjust if needed.
# `docker-compose.yml` reads these with sensible defaults, so .env is optional.

# ----- Ports exposed on the host -----
WEB_PORT=8080
MCP_PORT=3100
GENERATOR_PORT=3200
DB_PORT=5433

# ----- Postgres credentials -----
POSTGRES_USER=ugc
POSTGRES_PASSWORD=ugc
POSTGRES_DB=ugc

# ----- MCP server -----
# Bearer token clients must send as `Authorization: Bearer <token>`.
# Leave empty for local LAN trust. Generate a strong one with:
#   openssl rand -hex 32
MCP_TOKEN=

# ----- Generator service (Higgsfield CLI worker) -----
# Default: MOCK mode produces a placeholder image — no Higgsfield calls,
# no credits used. Validates the full pipeline.
# Once you've run `docker compose exec generator higgsfield auth login` inside
# the container, set GENERATOR_MOCK=false to use the real CLI.
GENERATOR_MOCK=true
GENERATOR_MAX_CONCURRENT=4
GENERATOR_POLL_MS=5000
GENERATOR_DEFAULT_MODEL=nano_banana_2

# ----- Cloudflare Tunnel (only needed if you start the tunnel profile) -----
# Get this token by creating a tunnel in the Cloudflare Zero Trust dashboard.
# Run with: `docker compose --profile tunnel up -d`
CLOUDFLARE_TUNNEL_TOKEN=
